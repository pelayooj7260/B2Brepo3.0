# ─────────────────────────────────────────────────────────────
# Self-hosted form submission config
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Choose one mode:
#   api      → POST to your own backend (see server/index.js)
#   webhook  → POST to Zapier / Make / n8n / etc.
#   mailto   → Opens the visitor's mail client (zero-backend fallback)
VITE_FORM_MODE=api

# Used when VITE_FORM_MODE=api  (leave as-is for local dev with server/index.js)
VITE_API_URL=/api/contact

# Used when VITE_FORM_MODE=webhook
# VITE_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_HOOK_ID

# Used when VITE_FORM_MODE=mailto
# VITE_CONTACT_EMAIL=hello@yourcompany.com

# ─────────────────────────────────────────────────────────────
# Stripe Payment Configuration (Vercel Serverless Backend)
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_51... # Your Stripe Secret Key
STRIPE_PRICE_STARTER=price_1... # Stripe Price ID for Starter ($249)
STRIPE_PRICE_FULL=price_1...    # Stripe Price ID for Full/Transformation Plan ($499)
STRIPE_PRICE_ENTERPRISE=price_1... # Stripe Price ID for Enterprise ($1200)
